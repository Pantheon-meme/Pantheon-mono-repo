# Copy to .env when a package or app needs local configuration.

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_TEXT_MODEL=google/gemini-3-flash-preview
OPENROUTER_IMAGE_MODEL=openai/gpt-5.4-image-2
OPENROUTER_SITE_URL=https://www.pantheon.meme
OPENROUTER_APP_NAME=Pantheon
# 0G
OG_RPC_URL=
OG_PRIVATE_KEY=
OG_STORAGE_ENDPOINT=
OG_STORAGE_INDEXER_RPC=
OG_STORAGE_URI_PREFIX=0g-storage://
OG_STORAGE_FINALITY_REQUIRED=false
OG_COMPUTE_ENDPOINT=

# Optional sponsor integrations
UNISWAP_API_KEY=
KEEPERHUB_API_KEY=
ENS_RPC_URL=
AXL_NODE_URL=http://localhost:8080

# MUD localnet game client
VITE_MUD_RPC_URL=http://127.0.0.1:8545
VITE_MUD_WORLD_ADDRESS=
VITE_MUD_PRIVATE_KEY=

# Local INFT agent dev minting
MUD_RPC_URL=http://127.0.0.1:8545
MUD_WORLD_ADDRESS=
PRIVATE_KEY=
AGENT_INFT_ADDRESS=
INFT_METADATA_MANIFEST=generated/inft-metadata/inft-assets.json
AGENT_EXECUTOR_PRIVATE_KEY=
AGENT_EXECUTOR_ADDRESS=
AGENT_PUBLIC_NAME=Aletheia
AGENT_PUBLIC_URI=0g-storage://local-dev/agents/aletheia/public.json
AGENT_ENCRYPTED_STORAGE_URI=0g-storage://local-dev/agents/aletheia/encrypted
AGENT_CAPSULE_URI=0g-storage://local-dev/agents/aletheia/capsule.enc.json
AGENT_MEMORY_CHECKPOINT_URI=0g-storage://local-dev/agents/aletheia/memory-checkpoint.enc.json
AGENT_STRATEGY_PROFILE_URI=0g-storage://local-dev/agents/aletheia/strategy-profile.enc.json
AGENT_AUTH_EXPIRES_AT=0
AGENT_MAX_ACTIONS_PER_EPOCH=256
AGENT_MAX_CUC_SPEND_PER_EPOCH=0
