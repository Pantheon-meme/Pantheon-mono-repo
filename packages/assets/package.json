{
  "name": "@pantheon/assets",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Mastra workflows and OpenRouter adapters for generating Pantheon world assets.",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "pantheon-assets": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "generate": "tsx src/cli.ts",
    "generate-autotiles": "tsx src/autotile-cli.ts",
    "combine-autotile-atlas": "tsx src/combine-autotile-atlas.ts",
    "publish-game-assets": "tsx src/publish-game-assets.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@mastra/core": "^0.16.0",
    "@openrouter/ai-sdk-provider": "^1.2.0",
    "ai": "^5.0.0",
    "sharp": "^0.33.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.6.3"
  }
}
