{
  "name": "@pantheon/assets",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Mastra workflows and OpenRouter adapters for generating Pantheon world assets.",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "pantheon-assets": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "generate": "tsx src/cli.ts",
    "generate-autotiles": "tsx src/autotile-cli.ts",
    "generate-terrain-autotiles": "tsx src/terrain-autotile-cli.ts",
    "generate-biome-terrain-assets": "tsx src/generate-biome-terrain-assets.ts",
    "generate-uniswap-biome-assets": "tsx src/generate-uniswap-biome-assets.ts",
    "generate-object-sprites": "tsx src/object-sprite-cli.ts",
    "generate-biome-object-sprites": "tsx src/generate-biome-object-sprites.ts",
    "generate-forage-item-sprites": "tsx src/generate-forage-item-sprites.ts",
    "generate-biome-plant-sprites": "tsx src/generate-biome-plant-sprites.ts",
    "generate-tree-sprites": "tsx src/generate-tree-sprites.ts",
    "combine-autotile-atlas": "tsx src/combine-autotile-atlas.ts",
    "prepare-inft-metadata": "tsx src/prepare-inft-metadata.ts",
    "upload-inft-metadata": "tsx src/prepare-inft-metadata.ts --upload",
    "publish-game-assets": "tsx src/publish-game-assets.ts",
    "publish-object-sprites": "tsx src/publish-object-sprites.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@mastra/core": "^0.16.0",
    "@0gfoundation/0g-storage-ts-sdk": "^1.2.6",
    "@openrouter/ai-sdk-provider": "^1.2.0",
    "ai": "^5.0.0",
    "ethers": "6.13.1",
    "sharp": "^0.33.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.6.3"
  }
}
