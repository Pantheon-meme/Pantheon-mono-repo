# Optional explicit Mastra model-router id. Examples:
# MASTRA_AGENT_MODEL=openai/gpt-5-mini
# MASTRA_AGENT_MODEL=openrouter/anthropic/claude-3.5-haiku
MASTRA_AGENT_MODEL=

# OpenAI fallback when OPENROUTER_API_KEY is not set.
OPENAI_API_KEY=your-api-key

# OpenRouter support. OPENROUTER_TEXT_MODEL may be either:
# - an OpenRouter model id, e.g. openai/gpt-4o-mini
# - a full Mastra router id, e.g. openrouter/openai/gpt-4o-mini
OPENROUTER_API_KEY=
OPENROUTER_TEXT_MODEL=openai/gpt-4o-mini
