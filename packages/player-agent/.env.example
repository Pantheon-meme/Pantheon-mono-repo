# Optional explicit Mastra model-router id. Examples:
# MASTRA_AGENT_MODEL=openai/gpt-5-mini
# MASTRA_AGENT_MODEL=openrouter/anthropic/claude-3.5-haiku
MASTRA_AGENT_MODEL=

# OpenAI fallback when OPENROUTER_API_KEY is not set.
OPENAI_API_KEY=your-api-key

# OpenRouter support. OPENROUTER_TEXT_MODEL may be either:
# - an OpenRouter model id, e.g. openai/gpt-4o-mini
# - a full Mastra router id, e.g. openrouter/openai/gpt-4o-mini
OPENROUTER_API_KEY=
OPENROUTER_TEXT_MODEL=openai/gpt-4o-mini

# Player loop defaults to deterministic economic-cycle mode, which avoids an LLM
# request per action. Set PLAYER_AGENT_USE_LLM=true to restore the old LLM loop,
# or PLAYER_AGENT_LLM_EVERY_TURNS=10 to ask the LLM for periodic strategy turns.
PLAYER_AGENT_USE_LLM=false
PLAYER_AGENT_LLM_EVERY_TURNS=0
PLAYER_AGENT_RADIUS=5
PLAYER_AGENT_MAX_FORAGES=4
PLAYER_AGENT_MAX_PICKUPS=4
PLAYER_AGENT_MAX_MOVE_STEPS=10
PLAYER_AGENT_MIN_ENERGY=20
PLAYER_AGENT_SELL_VALUE_THRESHOLD=48
PLAYER_AGENT_SELL_WEIGHT_RATIO=0.75
PLAYER_AGENT_PLANT_SEEDS=true

# INFT runtime binding. The executor key should be a hot key authorized by the
# INFT owner, not the custody key that owns/transfers the token.
AGENT_INFT_ADDRESS=
AGENT_TOKEN_ID=
AGENT_EXECUTOR_PRIVATE_KEY=

# Bank agent can use a different wallet than the player. Use the terrain admin
# key here if BANK_AGENT_ENSURE_AGENT=true.
BANK_AGENT_MUD_PRIVATE_KEY=
BANK_AGENT_THREAD_ID=central-uni-bank
BANK_AGENT_RESOURCE_ID=central-uni-bank
BANK_AGENT_USE_LLM=false
BANK_AGENT_ENSURE_AGENT=true
BANK_AGENT_TURN_DELAY_MS=30000
BANK_AGENT_PRICE_REFRESH_BUFFER_SECONDS=300
BANK_AGENT_MAX_TURNS=0
BANK_AGENT_MAX_STEPS=3
