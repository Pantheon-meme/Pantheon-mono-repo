{
  "name": "pantheon",
  "version": "0.0.0",
  "private": true,
  "description": "Pantheon monorepo for a deity, land, agent, and onchain game ecosystem.",
  "packageManager": "pnpm@9.4.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.0.6"
  }
}
